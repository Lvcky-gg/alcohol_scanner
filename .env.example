FLASK_RUN_PORT=5000
OCR_LANG=en
OCR_USE_GPU=false
OCR_SHOW_LOG=false
OCR_ENHANCE=false
OCR_UPSCALE_FACTOR=2.0
OCR_MULTI_PASS=false
OCR_ISOLATE_PROCESS=true
OCR_WORKER_TIMEOUT_SECONDS=60
OCR_CROP_PASSES=true
OCR_DET_LIMIT_SIDE_LEN=1536
OCR_DET_DB_BOX_THRESH=0.30
OCR_DET_DB_THRESH=0.25
OCR_REC_SCORE_THRESH=0.0
OCR_MIN_LINE_CHARS=2
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_SECONDS=60
OLLAMA_PROMPT_PATH=prompts/ollama_inference_prompt.txt
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# If backend runs in Docker and Ollama runs on host, use:
# OLLAMA_BASE_URL=http://host.docker.internal:11434
